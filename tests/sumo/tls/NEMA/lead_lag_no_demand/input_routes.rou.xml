<?xml version="1.0" encoding="UTF-8"?>

<!-- Traffic ONLY on sidestreet approaches (phases 3,4,7,8).
     NO traffic on mainstreet (phases 1,2,5,6) to test that the coordinated
     phases are still served even without any demand or recall. -->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <vType id="car" length="4.5" maxSpeed="25" accel="2.6" decel="4.5"/>

    <!-- Sidestreet through movements (phases 4 and 8) -->
    <flow id="f_NB_thru" type="car" from="4fi" to="3o" begin="0" end="1000" probability="0.08"/>
    <flow id="f_SB_thru" type="car" from="3fi" to="4o" begin="0" end="1000" probability="0.08"/>

    <!-- Sidestreet left turns (phases 7 and 3) -->
    <flow id="f_NB_left" type="car" from="4fi" to="2o" begin="0" end="1000" probability="0.04"/>
    <flow id="f_SB_left" type="car" from="3fi" to="1o" begin="0" end="1000" probability="0.04"/>
</routes>
