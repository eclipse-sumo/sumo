msgstr "Позиция прибытия на целевом ребре"

#: src/netedit/GNETagPropertiesDatabase.cpp:7325
msgid "Bus stop ID"
msgstr "ID автобусной остановки"

#: src/netedit/GNETagPropertiesDatabase.cpp:7331
